  "keywords": [
    "ductus",
    "agent",
    "coordination",
    "orchestration",
    "event-sourcing"
  ],
  "author": "Tsomaia Technologies",
  "license": "MIT",
  "dependencies": {
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "@types/uuid": "^10.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-jest-mock-import-meta": "^1.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "engines": {
