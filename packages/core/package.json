{
  "name": "ductus",
  "version": "1.0.4",
  "description": "Event sourcing framework built on async generators with processors, reactions, reducers, and agentic workflows",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
